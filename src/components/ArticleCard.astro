---
import type { ContentItem } from '@/lib/content';
import { formatDate } from '@/lib/content';
import { getCategoryName } from '@/lib/taxonomy';

type Props = {
  item: ContentItem;
};

const item = Astro.props.item;
---

<article class="content-card" data-pagefind-body>
  <div class="card-meta">
    <a href={`/category/${item.category}/`}>{getCategoryName(item.category)}</a>
    <time datetime={item.updatedAt.toISOString()}>{formatDate(item.updatedAt)}</time>
  </div>
  <h3><a href={item.url}>{item.title}</a></h3>
  <p>{item.description}</p>
  <div class="card-footer">
    <div class="tag-list mini">
      {item.tags.slice(0, 3).map((tag) => <a href={`/tag/${encodeURIComponent(tag)}/`}>#{tag}</a>)}
    </div>
    <span class="kind-label">{item.kind === 'post' ? '文章' : '资源'}</span>
  </div>
</article>
