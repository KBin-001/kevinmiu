---
type Props = {
  compact?: boolean;
};
---

<form class:list={['search-panel', { compact: Astro.props.compact }]} action="/search/" method="get">
  <label for="site-search">搜索资源、软件、教程和标签</label>
  <div class="search-row">
    <input id="site-search" name="q" type="search" placeholder="输入关键词，例如：限免、AI 工具、Windows、开发工具" />
    <button type="submit">搜索</button>
  </div>
</form>
