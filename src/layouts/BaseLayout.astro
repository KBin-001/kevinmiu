---
import '../styles/global.css';
import Header from '@/components/Header.astro';

type Props = {
  title?: string;
  description?: string;
  noindex?: boolean;
};

const siteName = 'kevinmiu';
const title = Astro.props.title ? `${Astro.props.title} | ${siteName}` : `${siteName} | 开发者资源库`;
const description =
  Astro.props.description ??
  'kevinmiu 收录资源福利、软件工具、开发工具、AI 工具、网站导航、教程文章和资讯动态。';
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://example.com').toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      const storedTheme = localStorage.getItem('theme');
      const preferredTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.dataset.theme = storedTheme ?? preferredTheme;
    </script>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {Astro.props.noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <a class="footer-logo" href="/" aria-label="kevinmiu 首页">
            <img src="/images/kevinmiu-logo.png" alt="" width="34" height="34" loading="lazy" decoding="async" />
            <span>kevinmiu</span>
          </a>
          <p>开发者值得收藏的工具、教程、资源与网站导航。</p>
        </div>
        <div class="footer-links" aria-label="页脚导航">
          <div>
            <span>Site</span>
            <a href="/about/">
              <svg aria-hidden="true" viewBox="0 0 24 24">
                <path d="M12 17v-6" />
                <path d="M12 7h.01" />
                <circle cx="12" cy="12" r="9" />
              </svg>
              关于本站
            </a>
            <a href="/#latest">
              <svg aria-hidden="true" viewBox="0 0 24 24">
                <path d="M4 19V5" />
                <path d="M8 17V9" />
                <path d="M12 17V7" />
                <path d="M16 17v-5" />
                <path d="M20 17V4" />
              </svg>
              更新统计
            </a>
            <a href="/rss.xml">
              <svg aria-hidden="true" viewBox="0 0 24 24">
                <path d="M5 19h.01" />
                <path d="M5 5a14 14 0 0 1 14 14" />
                <path d="M5 12a7 7 0 0 1 7 7" />
              </svg>
              RSS 订阅
            </a>
          </div>
          <div>
            <span>Contact</span>
            <a href="mailto:ypeng9490@gmail.com">
              <svg aria-hidden="true" viewBox="0 0 24 24">
                <path d="M4 6h16v12H4z" />
                <path d="m4 7 8 6 8-6" />
              </svg>
              ypeng9490@gmail.com
            </a>
            <a href="https://github.com/KBin-001" target="_blank" rel="noreferrer">
              <svg aria-hidden="true" viewBox="0 0 24 24">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5a10.4 10.4 0 0 0-5.5 0C8.5 2 7.5 2 7.5 2a6.6 6.6 0 0 0 0 3.5c-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                <path d="M9 18c-4.5 2-5-2-7-2" />
              </svg>
              GitHub
            </a>
            <a href="/search/">
              <svg aria-hidden="true" viewBox="0 0 24 24">
                <path d="m21 21-4.35-4.35" />
                <circle cx="10.5" cy="10.5" r="7.5" />
              </svg>
              站内搜索
            </a>
            <a href="/admin/" rel="nofollow">
              <svg aria-hidden="true" viewBox="0 0 24 24">
                <path d="M12 3 4 6v6c0 5 3.4 8 8 9 4.6-1 8-4 8-9V6l-8-3Z" />
                <path d="m9 12 2 2 4-5" />
              </svg>
              内容后台
            </a>
          </div>
        </div>
        <div class="footer-bottom">
          <span>© 2026 kevinmiu. Curated for builders.</span>
          <a href="mailto:ypeng9490@gmail.com">ypeng9490@gmail.com</a>
        </div>
      </div>
    </footer>
    <script is:inline>
      (() => {
        const params = new URLSearchParams(window.location.search);
        const highlightQuery = params.get('highlight');
        if (!highlightQuery?.trim()) return;

        const getTerms = (query) =>
          [...new Set(query.trim().split(/\s+/).filter((term) => term.length >= 2 || /[\u4e00-\u9fff]/.test(term)))].slice(
            0,
            6
          );

        const terms = getTerms(highlightQuery);
        if (!terms.length) return;

        const escapeRegExp = (value) => value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        const pattern = new RegExp(`(${terms.map(escapeRegExp).join('|')})`, 'gi');
        const roots = Array.from(
          document.querySelectorAll('.article-header h1, .article-header > p, .prose')
        ).filter((element) => !element.hasAttribute('hidden'));

        if (!roots.length) return;

        const shouldSkipNode = (node) => {
          const parent = node.parentElement;
          return (
            !parent ||
            parent.closest(
              'script, style, noscript, svg, mark, input, textarea, select, button, nav, .tag-list, .attachment-item, .resource-action-button, .access-gate'
            )
          );
        };

        const highlighted = [];

        for (const root of roots) {
          const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
            acceptNode(node) {
              if (shouldSkipNode(node)) return NodeFilter.FILTER_REJECT;
              if (!node.nodeValue || !pattern.test(node.nodeValue)) return NodeFilter.FILTER_REJECT;
              pattern.lastIndex = 0;
              return NodeFilter.FILTER_ACCEPT;
            }
          });

          const textNodes = [];
          while (walker.nextNode()) textNodes.push(walker.currentNode);

          for (const node of textNodes) {
            const fragment = document.createDocumentFragment();
            const parts = node.nodeValue.split(pattern);

            for (const part of parts) {
              if (!part) continue;
              pattern.lastIndex = 0;
              if (pattern.test(part)) {
                const mark = document.createElement('mark');
                mark.className = 'search-jump-highlight';
                mark.textContent = part;
                fragment.append(mark);
                highlighted.push(mark);
              } else {
                fragment.append(document.createTextNode(part));
              }
            }

            node.parentNode?.replaceChild(fragment, node);
          }
        }

        const firstHighlight = highlighted[0];
        if (!firstHighlight) return;

        window.setTimeout(() => {
          firstHighlight.scrollIntoView({ behavior: 'smooth', block: 'center' });
          firstHighlight.classList.add('is-current');
        }, 120);
      })();
    </script>
  </body>
</html>
