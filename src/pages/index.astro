---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SearchBox from '@/components/SearchBox.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import { formatDate, getAllContentItems, getAllTags } from '@/lib/content';

const items = await getAllContentItems();
const resourceCount = items.filter((item) => item.kind === 'resource').length;
const postCount = items.filter((item) => item.kind === 'post').length;
const latestUpdatedAt = items[0]?.updatedAt;
const featuredItems = items.filter((item) => item.featured).slice(0, 3);
const featured = featuredItems.length > 0 ? featuredItems : items.slice(0, 3);
const featuredUrls = new Set(featured.map((item) => item.url));
const latest = items.filter((item) => !featuredUrls.has(item.url));
const tags = getAllTags(items).slice(0, 5);
---

<BaseLayout>
  <section class="home-hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container hero-center">
      <p class="eyebrow">Curated tools for builders</p>
      <h1><span>开发者值得收藏的</span><span>工具与资源</span></h1>
      <p>看山是山，看山不是山，再看山是山。</p>
      <SearchBox />
      <div class="hot-searches" aria-label="热门搜索">
        <span>热门：</span>
        {tags.map((tag) => <a href={`/tag/${encodeURIComponent(tag)}/`}>#{tag}</a>)}
      </div>
      <div class="hero-stats" aria-label="站点统计">
        <span>
          <strong>{resourceCount}</strong>
          个资源
        </span>
        <span>
          <strong>{postCount}</strong>
          篇文章
        </span>
        {
          latestUpdatedAt && (
            <span>
              最近更新 <strong>{formatDate(latestUpdatedAt)}</strong>
            </span>
          )
        }
      </div>
    </div>
  </section>

  <section class="container section-block featured-section">
    <div class="section-heading row-heading">
      <div>
        <p class="section-kicker">Editor's picks</p>
        <h2>今日推荐</h2>
      </div>
      <a class="section-more" href="/search/">更多资源</a>
    </div>
    <div class="feature-grid">
      {featured.map((item, index) => <ArticleCard item={item} variant="featured" index={index} />)}
    </div>
  </section>

  <section id="latest" class="container section-block latest-section">
    <div class="section-heading row-heading">
      <div>
        <p class="section-kicker">Latest feed</p>
        <h2>最新内容</h2>
      </div>
      <div class="filter-tabs" aria-label="内容筛选" data-filter-tabs>
        <button type="button" class="is-active" data-filter="all">全部</button>
        <button type="button" data-filter="tools">工具</button>
        <button type="button" data-filter="post">文章</button>
        <button type="button" data-filter="websites">导航</button>
      </div>
    </div>
    {
      latest.length > 0 ? (
        <>
          <div class="card-grid latest-grid" data-filter-grid>
            {latest.map((item) => <ArticleCard item={item} variant="stream" />)}
          </div>
          <nav class="latest-pagination" aria-label="最新内容分页" data-pagination hidden>
            <button type="button" data-page-prev>上一页</button>
            <span data-page-status>第 1 / 1 页</span>
            <button type="button" data-page-next>下一页</button>
          </nav>
          <div class="empty-state latest-empty" data-filter-empty hidden>
            <div class="empty-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M4 7.5A2.5 2.5 0 0 1 6.5 5h11A2.5 2.5 0 0 1 20 7.5v9A2.5 2.5 0 0 1 17.5 19h-11A2.5 2.5 0 0 1 4 16.5v-9Z" />
                <path d="M8 9h8M8 13h5" />
              </svg>
            </div>
            <div>
              <strong>当前分类暂无内容</strong>
              <span>可以先查看全部内容，后续新增资源会自动出现在这里。</span>
            </div>
            <button type="button" data-filter-reset>查看全部内容</button>
          </div>
        </>
      ) : (
        <div class="empty-state latest-empty">
          <div class="empty-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M4 7.5A2.5 2.5 0 0 1 6.5 5h11A2.5 2.5 0 0 1 20 7.5v9A2.5 2.5 0 0 1 17.5 19h-11A2.5 2.5 0 0 1 4 16.5v-9Z" />
              <path d="M8 9h8M8 13h5" />
            </svg>
          </div>
          <div>
            <strong>暂无更多最新内容</strong>
            <span>当前示例内容已经全部展示。</span>
          </div>
        </div>
      )
    }
  </section>

  <script is:inline>
    const tabRoot = document.querySelector('[data-filter-tabs]');
    const grid = document.querySelector('[data-filter-grid]');
    const empty = document.querySelector('[data-filter-empty]');
    const reset = document.querySelector('[data-filter-reset]');
    const pagination = document.querySelector('[data-pagination]');
    const pagePrev = document.querySelector('[data-page-prev]');
    const pageNext = document.querySelector('[data-page-next]');
    const pageStatus = document.querySelector('[data-page-status]');
    const tabs = Array.from(tabRoot?.querySelectorAll('[data-filter]') ?? []);
    const cards = Array.from(grid?.querySelectorAll('[data-category]') ?? []);
    const toolCategories = ['software', 'dev-tools', 'ai-tools'];
    const pageSize = 9;
    let activeFilter = 'all';
    let currentPage = 1;

    function getMatchedCards(filter) {
      return cards.filter((card) => {
        const category = card.getAttribute('data-category');
        const kind = card.getAttribute('data-kind');
        return (
          filter === 'all' ||
          category === filter ||
          kind === filter ||
          (filter === 'tools' && toolCategories.includes(category ?? ''))
        );
      });
    }

    function renderLatest() {
      const matchedCards = getMatchedCards(activeFilter);
      const totalPages = Math.max(1, Math.ceil(matchedCards.length / pageSize));
      currentPage = Math.min(currentPage, totalPages);
      currentPage = Math.max(1, currentPage);
      const start = (currentPage - 1) * pageSize;
      const end = start + pageSize;
      const visibleCards = new Set(matchedCards.slice(start, end));

      cards.forEach((card) => {
        card.toggleAttribute('hidden', !visibleCards.has(card));
      });

      empty?.toggleAttribute('hidden', matchedCards.length !== 0);

      if (pagination) {
        const shouldShowPagination = matchedCards.length > pageSize;
        pagination.toggleAttribute('hidden', !shouldShowPagination);
      }

      if (pageStatus) {
        pageStatus.textContent = `第 ${currentPage} / ${totalPages} 页`;
      }

      if (pagePrev instanceof HTMLButtonElement) {
        pagePrev.disabled = currentPage <= 1;
      }

      if (pageNext instanceof HTMLButtonElement) {
        pageNext.disabled = currentPage >= totalPages;
      }
    }

    function setFilter(filter) {
      activeFilter = filter;
      currentPage = 1;
      renderLatest();
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        tabs.forEach((item) => item.classList.toggle('is-active', item === tab));
        setFilter(tab.getAttribute('data-filter') ?? 'all');
      });
    });

    pagePrev?.addEventListener('click', () => {
      currentPage = Math.max(1, currentPage - 1);
      renderLatest();
      document.querySelector('#latest')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    pageNext?.addEventListener('click', () => {
      currentPage += 1;
      renderLatest();
      document.querySelector('#latest')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    reset?.addEventListener('click', () => {
      const allTab = tabs.find((tab) => tab.getAttribute('data-filter') === 'all');
      tabs.forEach((item) => item.classList.toggle('is-active', item === allTab));
      setFilter('all');
    });

    renderLatest();
  </script>
</BaseLayout>
